# Copy this file to .env and fill in your values
# Then: source .env

# Groq API key — free at console.groq.com (no credit card)
# 14,400 requests/day free tier — demo uses ~12 calls
export GROQ_API_KEY=your_key_here

# Force Ollama even if GROQ_API_KEY is set
# Useful for offline demo or data residency requirements
# export USE_OLLAMA=1
